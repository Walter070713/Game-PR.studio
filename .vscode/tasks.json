{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build raylib game",
            "type": "process",
            "command": "gcc",
            "args": [
                "main.c",
                // "Player/Player.c",
                // "Camera/CameraSet.c",
                // "Mouse/MouseAim.c",
                "-o", "game.exe",
                "-I", "include",
                // "-I", "Player",
                // "-I", "Camera",
                // "-I", "Mouse",
                "-L", "lib",
                "-lraylib",
                "-lopengl32",
                "-lgdi32",
                "-lwinmm"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"]
        }
    ]
}